-- =====================================================
-- QUERIES
-- =====================================================

-- 1. Suppliers who supply GREEN parts

SELECT DISTINCT s.sname
FROM supplier s
JOIN catalog c ON s.supplierid = c.supplierid
JOIN parts p ON c.part_id = p.part_id
WHERE p.color = 'green';

-- 2. Suppliers who supply BOTH blue AND green parts

SELECT s.sname
FROM supplier s
JOIN catalog c ON s.supplierid = c.supplierid
JOIN parts p ON c.part_id = p.part_id
WHERE p.color IN ('blue', 'green')
GROUP BY s.supplierid, s.sname
HAVING COUNT(DISTINCT p.color) = 2;

-- 3. Suppliers who supply ALL parts

SELECT s.sname
FROM supplier s
JOIN catalog c ON s.supplierid = c.supplierid
GROUP BY s.supplierid, s.sname
HAVING COUNT(DISTINCT c.part_id) = (
    SELECT COUNT(*) FROM parts
);

-- 4. Total cost of RED parts

SELECT SUM(c.cost) AS total_red_cost
FROM catalog c
JOIN parts p ON c.part_id = p.part_id
WHERE p.color = 'red';

-- 5. Supplier supplying GREEN parts with MINIMUM cost

SELECT s.sname, c.cost
FROM supplier s
JOIN catalog c ON s.supplierid = c.supplierid
JOIN parts p ON c.part_id = p.part_id
WHERE p.color = 'green'
AND c.cost = (
    SELECT MIN(c2.cost)
    FROM catalog c2
    JOIN parts p2 ON c2.part_id = p2.part_id
    WHERE p2.color = 'green'
);

-- 6. Update color of part having part_id = 4 (supplier_id logically not needed)

UPDATE parts
SET color = 'blue'
WHERE part_id = 4;

