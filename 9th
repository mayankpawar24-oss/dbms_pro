-- 2. Update CopiesAvailable when a book is borrowed (example: BookID = 101)

UPDATE Books
SET CopiesAvailable = CopiesAvailable - 1
WHERE BookID = 101;

-- When book is returned (example: BookID = 101)

UPDATE Books
SET CopiesAvailable = CopiesAvailable + 1
WHERE BookID = 101;

-- 3. Member Name, Book Title, Borrow Date for last 1 month

SELECT m.Name, b.Title, bb.BorrowDate
FROM Members m
JOIN BorrowedBooks bb ON m.MemberID = bb.MemberID
JOIN Books b ON bb.BookID = b.BookID
WHERE bb.BorrowDate >= DATE_SUB(CURDATE(), INTERVAL 1 MONTH);

-- 4. Number of books borrowed per genre

SELECT b.Genre, COUNT(*) AS total_borrowed
FROM BorrowedBooks bb
JOIN Books b ON bb.BookID = b.BookID
GROUP BY b.Genre;

-- 5. Top 5 members who borrowed most books

SELECT m.Name, COUNT(bb.BorrowID) AS total_books
FROM Members m
JOIN BorrowedBooks bb ON m.MemberID = bb.MemberID
GROUP BY m.MemberID, m.Name
ORDER BY total_books DESC
LIMIT 5;
